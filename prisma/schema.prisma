// Prisma schema for Atlas Day 2
// Database: Supabase Postgres (direct connection)
// Run: pnpm prisma generate (after DATABASE_URL is set in .env.local)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id           String   @id @default(cuid())
  userId       String
  vertical     String
  questionText String   @db.Text
  responseJson Json
  createdAt    DateTime @default(now())

  // Day 10: user feedback. The user can rate each result with a
  // thumbs up (1), thumbs down (-1), or no rating (null). The
  // optional note is a free-form comment up to 500 chars — what
  // did the user actually do with the result, what was wrong.
  // This is the start of Atlas's data moat: every rated result
  // teaches us which site recommendations were actually useful.
  rating     Int?     // -1 = thumbs down, 1 = thumbs up, null = not rated
  ratingNote String?  @db.Text
  ratedAt    DateTime?

  @@index([userId, createdAt])
  @@index([vertical, rating])
}

// Day 10+: User-added listings (Path 4 — the "Add a listing" feature).
// A Plot is a specific plot of land a user is tracking or has spotted
// for sale. Plot rows are PRIVATE to the user who created them
// (isPublic = false by default). v2 will let users share with their
// team.
//
// We store both the user-typed fields (suburb, city, size, price,
// agent) AND the provenance (source: user / property24_url / manual /
// import, sourceUrl: the pasted URL). This lets us:
//   - Show listings on the result page as priced markers
//   - Build a per-suburb pricing database over time (the moat)
//   - Dedupe listings by sourceUrl so the same Property24 link
//     doesn't get added 5 times
model Plot {
  id          String   @id @default(cuid())
  userId      String
  // Optional — ties a plot to the question that surfaced it.
  // Orphan plots (no questionId) appear in the user's "My plots"
  // list but not in any result page overlay.
  questionId  String?

  // Location
  suburb      String                       // "Sandton CBD", "Morningside"
  city        String                       // "Sandton", "Cape Town", "Lusaka"
  country     String   @default("South Africa")
  lat         Float?                       // optional, from URL or manual
  lng         Float?                       // optional

  // Listing data
  // BigInt for price so we can fit 7-digit ZAR prices (R 9,999,999)
  // and 9-digit NGN prices (₦ 999,999,999) without overflow.
  sizeM2      Int?
  priceAmount BigInt?
  currency    String   @default("ZAR")
  listingType String   @default("for_sale") // for_sale | auction | tender | off_market
  agentName   String?

  // Provenance
  source      String   @default("user")   // user | property24_url | manual | import
  sourceUrl   String?                     // the pasted URL
  notes       String?  @db.Text

  // Privacy
  //
  // Day 11 LinkedIn-style privacy:
  //
  // isPublic was a single bit. v1.1 splits it into two so the
  // user controls:
  //
  //   publishToMarket: should this listing appear in OTHER
  //     users' "Listings in this area" sections? Default true.
  //     The "data fields" (suburb, city, size, price, currency,
  //     listing type, lat/lng) are always shared when this is
  //     true. The "contact fields" (agent name, source URL,
  //     notes) are gated separately below.
  //
  //   revealContact: should OTHER users see the contact fields
  //     (agent name, source URL)? Default false. Set to true to
  //     let other users click through to the original Property24
  //     listing. We never share `notes` to other users — that's
  //     a private field the owner keeps for themselves.
  //
  // The owner always sees everything regardless of these flags.
  isPublic       Boolean  @default(false)    // legacy: kept for backward compat
  publishToMarket Boolean @default(true)    // share data fields with the Atlas market
  revealContact  Boolean  @default(false)   // share contact fields (agent, sourceUrl) with the market

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, sourceUrl])             // dedupe same URL per user
  @@index([userId, createdAt])
  @@index([questionId])
  @@index([city, suburb])
  // Cross-user market: queries like "show published plots in
  // Sandton" hit this index for O(log n) lookup.
  @@index([publishToMarket, city, suburb])
}

// Day 9: waitlist signups for the paid plan. We store a minimal
// record so we can track interest, segment by vertical, and
// follow up. No PII beyond name + email + vertical — the user
// gives consent at signup time.
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String
  name      String?
  vertical  String
  plan      String   // "free" | "pro" | "team"
  // What the user told us they want. Free-form text, capped at 500 chars.
  message   String?
  // Soft "I'm interested" flag — separate from the join itself.
  // Lets us segment "ready to pay" vs "just curious".
  userType  String?  // "land_developer" | "property_investor" | "residential_builder" | "other"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([plan])
}

// Day 14: User table with plan + payment processor linkage.
//
// Why we need this: the Stripe webhook at /api/stripe/webhook
// and PayFast ITN at /api/payfast/itn need a place to write
// "this Clerk user is now a paying Pro/Team subscriber" so the
// rest of the app can gate features by plan.
//
// We use the Clerk user ID as the primary key. When a user signs
// up, Clerk's auth() returns userId; we upsert a User row with
// that ID. The Stripe/PayFast webhook receives a client_reference_id
// (Stripe) or custom_str1 (PayFast) which is the Clerk user ID.
//
// Plan values: "free" (default), "pro" (R250/mo), "team"
// (R2,500/mo). Future plan values go in the same enum (e.g.
// "enterprise").
//
// stripeCustomerId + stripeSubscriptionId are the Stripe side of
// the linkage. payfastPaymentId + payfastToken are the PayFast
// side. Either set is sufficient — only one payment processor
// is active at a time per user.
model User {
  id                   String   @id  // Clerk user ID (string, not numeric)
  email                String   @unique
  plan                 String   @default("free")  // "free" | "pro" | "team"
  // Stripe linkage
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  // PayFast linkage
  payfastPaymentId     String?  @unique
  payfastToken         String?  @unique
  payfastMPaymentId    String?  @unique
  // When the subscription was last updated by either webhook
  planUpdatedAt        DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([plan])
  @@index([plan, planUpdatedAt])
  // Day 18: reverse relation so prisma includes threads + messages
  // when fetching a user.
  threads              Thread[]
}

// Day 18: Thread = a Perplexity-style chat conversation. Holds an
// ordered list of Messages. One user can have many threads.
//
// A thread's first user message becomes its `title` (truncated to 80
// chars) so the /dashboard list is scannable. The full chat history
// lives in the messages relation, ordered by createdAt asc.
model Thread {
  id        String   @id @default(cuid())
  userId    String
  title     String
  // Cached count of messages so the sidebar can render "12 messages"
  // without an extra count query on every list render.
  messageCount Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
  @@index([userId, createdAt])
}

// Day 18: Message = one turn in a chat thread. Either a user prompt
// or an assistant response. The assistant messages store the Tavily
// + Gemini response: prose content, clickable sources, intent.
//
// When the user clicks 'View data' on an assistant message, the
// spatial engine (/api/ask with selected model) runs on the same
// question and stores the resulting questionId in
// `spatialQuestionId`. The chat page renders this as a chip below
// the message — click it to open /result/[spatialQuestionId].
model Message {
  id        String   @id @default(cuid())
  threadId  String
  role      String   // "user" | "assistant"
  // User prompt OR assistant prose. For assistant messages this is
  // the markdown-ish answer body from Tavily + Gemini.
  content   String   @db.Text
  // The user question that produced this message. Always set on
  // user messages and on assistant messages that are replies to a
  // user message. Used as the input to View Data.
  question  String?
  // Assistant-only: "spatial" or "conversational" intent classification.
  intent    String?
  // Assistant-only: array of {title, url} from Tavily. Stored as JSON.
  sources   Json?
  // Day 18: if the user clicked View Data on this assistant message,
  // this is the questionId from /api/ask (the spatial view's row).
  spatialQuestionId String?
  // Day 18: which model produced the spatial view, if any.
  spatialModel      String?
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
